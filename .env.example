# Readwise API token — get yours at https://readwise.io/access_token
READWISE_API_KEY=your_token_here

# Secret used to protect write endpoints (/sync, /refresh).
# Choose a long random string. Keep this private.
ADMIN_SECRET=choose_a_long_random_string_here

# Optional HTTP Basic Auth — protects all pages when hosting publicly.
# Leave both blank (or omit) for local dev. Set both to enable.
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
